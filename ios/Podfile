# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# Enable New Architecture (required for react-native-reanimated 4.x)
ENV['RCT_NEW_ARCH_ENABLED'] = '1'

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Fix for react-native-reanimated RNWorklets issue
source 'https://cdn.cocoapods.org/'

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'MdTelemed' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    
    # Fix for react-native-reanimated with New Architecture
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.4'
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'RCT_NEW_ARCH_ENABLED=1'
        
        # Keep New Architecture compatible C++ standard by default
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'
        config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'

        # Xcode can treat this as an error for Pods; allow non-modular includes
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        config.build_settings['CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'

        # Silence "non-modular-include-in-framework-module" when promoted to error
        config.build_settings['OTHER_CFLAGS'] ||= ['$(inherited)']
        config.build_settings['OTHER_CFLAGS'] << '-Wno-non-modular-include-in-framework-module'
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] ||= ['$(inherited)']
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] << '-Wno-non-modular-include-in-framework-module'

        # `fmt` (used by RCT-Folly) can fail with C++20 consteval in some Xcode/Pod setups.
        # Build `fmt` with C++17 while keeping the rest on C++20.
        if target.name == 'fmt'
          config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
        end
      end
    end

    # Some vendored xcframeworks (notably Agora) can end up embedded with 0644 permissions,
    # which makes dyld treat them as not-loadable at runtime. Ensure embedded framework
    # binaries are executable by patching the CocoaPods embed frameworks script.
    frameworks_script = File.join(__dir__, 'Pods', 'Target Support Files', 'Pods-MdTelemed', 'Pods-MdTelemed-frameworks.sh')
    if File.exist?(frameworks_script)
      script = File.read(frameworks_script)
      unless script.include?('chmod +x "$binary"')
        marker = "\n\n  # Strip invalid architectures so \"fat\" simulator / device frameworks work on device\n"
        insertion = <<~'SH'

          # Ensure embedded framework binaries are executable
          if [ -f "${binary}" ]; then
            chmod +x "${binary}" || true
          fi
SH
        script = script.sub(marker, insertion + marker)
        File.write(frameworks_script, script)
      end
    end
  end
end
